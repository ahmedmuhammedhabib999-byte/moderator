# Backend configuration (do NOT commit secrets to version control)
# Copy this file to .env and fill in your values.

# OpenAI API key used for AI-powered analysis and code generation
OPENAI_API_KEY=your_openai_api_key_here

# Secret key used to sign JWT tokens
SECRET_KEY=your_jwt_secret_key_here

# Optional: SQLite database URL (defaults to local modforge.db)
# DATABASE_URL=sqlite:///./modforge.db

# Optional: comma-separated list of allowed origins for CORS (e.g. https://your-frontend.onrender.com)
# CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com
